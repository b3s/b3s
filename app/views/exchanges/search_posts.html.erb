<% content_for(:body_class, "search search_posts_in_discussion") %>
<% content_for(:page_title, @exchange.title + " - Search: " + h(search_query)) %>

<h2 class="section">
  <% if @exchange.labels? %>
    [<%= @exchange.labels.join(",") %>]
  <% end %>
  <%= link_to @exchange.title, @exchange, id: "discussionLink" %>
  &raquo;
  Search: <em><%= search_query %></em>
</h2>

<%= render partial: "search/tips" %>

<% if @posts && @posts.length > 0 %>
  <%= render(partial: "components/pagination",
             locals: { p: @posts, anchor: :start,
                       pagination_params: { q: search_query } }) %>
  <div class="posts">
    <%= render(partial: "posts/post", collection: @posts) %>
  </div>
  <%= render(partial: "components/pagination",
             locals: { p: @posts, anchor: :start,
                       pagination_params: { q: search_query } }) %>
<% else %>
  <p>
    No posts were found.
  </p>
<% end %>
