<% content_for(:body_class, "user_profile posts") %>
<% content_for(:page_title, "#{@user.username}'s Posts") %>

<h2 class="section">
  <%= link_to "Users", users_path %> &raquo;
  <%= profile_link(@user) %> &raquo;
  <%= link_to "Posts", user_profile_posts_path( @user.username) %>
</h2>

<% if @posts %>
  <%= render(partial: "components/pagination",
             locals: { paginated: @posts, anchor: :start }) %>
  <%= render(partial: "posts/list", locals: { posts: @posts }) %>
  <%= render(partial: "components/pagination",
             locals: { paginated: @posts, anchor: :start }) %>
<% else %>
  <p>
    No posts were found.
  </p>
<% end %>
