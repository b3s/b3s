<% content_for(:body_class, "users") %>
<% content_for(:page_title, "Online Users") %>

<div class="functions">
  <%= render partial: "users/lists/functions" %>
</div>

<h2 class="section">
  <%= link_to "Users", users_path %> &raquo;
  <%= link_to "Online", online_users_path %>
</h2>

<%= render partial: "users/lists/navigation" %>

<div class="content">
  <p>
    <% if @users.length == 1 %>
      <strong>1</strong>
      user is online right now.
    <% elsif @users.length > 1 %>
      <strong><%= @users.length %></strong>
      users are online right now.
    <% else %>
      No users are online.
    <% end %>
  </p>
</div>

<% if @users.length > 0 %>
  <%= render(partial: "users/lists/listing",
             locals: {
               users: @users,
               columns: [:username, :location, :member_since, :status] }) %>
<% end %>
