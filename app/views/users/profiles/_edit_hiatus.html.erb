<%# locals: (f:, user:) %>
<%= f.labelled_datetime_select(:hiatus_until,
                               minute_step: 15,
                               default: 1.minute.ago) %>
<% unless user.time_zone? %>
  <p>
    <strong>
      <%= t("user.edit.warning") %>:
    </strong>
    <%= t("user.edit.missing_time_zone_link_html",
          link: link_to(t("user.edit.chosen_a_time_zone"),
                        edit_user_profile_path(user.username,
                                            "location"))) %>
  </p>
<% end %>
