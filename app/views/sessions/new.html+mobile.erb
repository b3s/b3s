<% content_for(:page_title, "Please log in") %>

<section class="login">
  <div class="login_box">
    <%= form_tag(session_path, class: "form") do %>
      <p>
        <label>Email</label>
        <%= text_field_tag "email", "", class: :text %>
      </p>

      <p>
        <label>Password</label>
        <%= password_field_tag "password", "", class: :text %>
      </p>

      <p>
        <%= submit_tag "Login" %>
      </p>
    <% end %>
  </div>

  <div id="login-functions">
    <p>
      <%= link_to "Password reminder", new_password_reset_path %>
      <span class="separator">|</span>
      <%= link_to "Regular site", mobile_format: "html" %>
    </p>
  </div>
</section>
