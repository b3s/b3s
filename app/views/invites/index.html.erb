<% content_for(:body_class, "invites") %>
<% content_for(:page_title, "Invites") %>

<div class="functions"></div>

<h2 class="section">
  <%= link_to "Invites", invites_path %>
</h2>

<div class="content">
  <% if current_user.available_invites? %>
    <% if current_user.user_admin? %>
      <p>
        You are a user admin, and can
        <%= link_to("invite as many people as you like",
                    new_invite_path) %>.
        You can also grant other users invites from their profile pages.
        <%= link_to("Click here to view everyone's invites",
                    all_invites_path) %>.
      </p>
      <p>
        Sent invites will expire after 14 days, and will be returned if unused
        or cancelled.
      </p>
    <% elsif current_user.available_invites? %>
      <p>
        You have
        <strong><% if current_user.available_invites == 1 %>one available invite<% else %><%= current_user.available_invites %>available invites<% end %></strong>,
        <%= link_to "click here to invite someone", new_invite_path %>. Sent
        invites will expire after 14 days, and will be returned if unused or
        cancelled.
      </p>
    <% end %>
  <% else %>
    <p>
      You don't currently have any available invites.
      <% if current_user.invites? %>
        You can cancel one of your invites to reclaim it, or wait until they
        expire.
      <% end %>
    </p>
  <% end %>
</div>

<% if @invites && @invites.length > 0 %>
  <table class="list invites_list">
    <tr>
      <th>Email</th>
      <th>Sent</th>
      <th>Expires</th>
      <th></th>
    </tr>

    <% @invites.each do |invite| %>
      <tr>
        <td class="email">
          <%= invite.email %>
        </td>

        <td class="created_at">
          <%= time_tag invite.created_at, class: "relative" %>
        </td>

        <td class="expires_at">
          <%= invite.expires_at.strftime("%b %d, %Y") %>
        </td>

        <td class="actions">
          <%= link_to("Cancel",
                      invite_path(invite),
                      class: :delete,
                      method: :delete,
                      data: {
                        confirm: "Are you sure that you want to cancel this invite?"
                      }) %>
        </td>
      </tr>
    <% end %>
  </table>
<% end %>
