<% content_for(:body_class, "search search_posts") %>
<% content_for(:page_title, "Posts Search") %>

<%= content_for :sidebar do %>
  <%= render partial: "discussions/sidebar" %>
<% end %>

<h2 class="section">
  Searching posts for <em><%= search_query %></em>
</h2>

<%= render partial: "search/tips" %>

<% if @posts && @posts.length > 0 %>
  <%= render(partial: "components/pagination",
             locals: { p: @posts, anchor: :start,
                       pagination_params: { q: search_query } }) %>
  <%= render(partial: "posts/list", locals: { posts: @posts }) %>
  <%= render(partial: "components/pagination",
             locals: { p: @posts, anchor: :start,
                       pagination_params: { q: search_query } }) %>
<% else %>
  <p>
    No posts were found.
  </p>
<% end %>
