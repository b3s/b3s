{
  "name": "app",
  "packageManager": "pnpm@11.1.1",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@rails/actioncable": "^8.1.300",
    "@rails/ujs": "^7.1.600",
    "autoprefixer": "^10.5.0",
    "downshift": "^9.3.3",
    "dropzone": "6.0.0-beta.2",
    "esbuild": "^0.28.0",
    "match-sorter": "^8.3.0",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "postcss-image-inliner": "^7.0.1",
    "postcss-import": "^16.1.1",
    "postcss-import-ext-glob": "^2.1.1",
    "postcss-mixins": "^11.0.3",
    "postcss-nested": "^7.0.2",
    "postcss-url": "^10.1.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tombolo": "^0.10.0",
    "underscore": "^1.13.8",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.4",
    "@herb-tools/formatter": "^0.10.1",
    "@herb-tools/linter": "^0.10.1",
    "@types/dropzone": "^5.7.9",
    "@types/rails__ujs": "^6.0.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "lint": "eslint 'app/javascript'",
    "lint:herb": "herb-lint",
    "format:herb": "herb-format --check .",
    "format:herb:fix": "herb-format .",
    "build": "pnpm run build-dev --minify",
    "build-dev": "esbuild app/javascript/application.ts app/javascript/mobile.ts --bundle --sourcemap --outdir=app/assets/builds --target=es2020",
    "build:css": "postcss './app/assets/stylesheets/**/*.postcss' --base ./app/assets/stylesheets --dir ./app/assets/builds --ext css",
    "prettier": "prettier app/javascript app/assets/stylesheets --check",
    "prettier:fix": "prettier app/javascript app/assets/stylesheets --write"
  }
}
